@page "/"
@namespace RiseFlow.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RiseFlow</title>
    <base href="~/" />
    <link rel="stylesheet" href="css/rf-home-fallback.css" />
    <!-- Load Tailwind via official CDN so utility classes take effect -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full bg-slate-50 dark:bg-slate-950">
    <app>
        <component type="typeof(App)" render-mode="ServerPrerendered" />
    </app>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js"
            integrity="sha512-hLOmYiBzbHUJBq8XX7x2gFl6i90WPS7P4Th4vK7uWVyq5AFM1yrEn8NsLAqXhZ0m3id4z+XBblgDTcdjz0sG4Q=="
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="js/theme.js"></script>
    <script src="js/lottie-init.js"></script>
    <script src="_framework/blazor.server.js"></script>
</body>
</html>